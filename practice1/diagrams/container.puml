@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title Диаграмма контейнеров: Система дедупликации запросов

Person(клиент, "API-клиент", "Мобильное приложение или сервис")

System_Boundary(система, "Система дедупликации") {
    Container(шлюз, "API-шлюз", "FastAPI / Python", "Принимает запросы, валидирует ключи, проверяет кэш")
    Container(хранилище, "Хранилище ключей", "Redis", "Хранит ключи и кэшированные ответы (TTL)")
    ContainerQueue(очередь, "Очередь задач", "Redis Streams", "Буферизация задач для асинхронной обработки")
    Container(воркер, "Исполнитель операций", "Python + Celery", "Выполняет реальную операцию для заданного ключа")
}

System_Ext(бизнес_логика, "API бизнес-логики", "Сервис платежей/заказов (внешний)")
System_Ext(мониторинг, "Prometheus + Grafana", "Сбор метрик и визуализация")

' Клиент -> Шлюз
Rel(клиент, шлюз, "Отправляет запрос с Idempotency-Key", "HTTP/REST")

' Шлюз -> Хранилище (синхронная проверка)
Rel(шлюз, хранилище, "Проверка ключа / получение кэша", "RESP (Redis Protocol)")

' Шлюз -> Очередь (при промахе кэша)
Rel(шлюз, очередь, "Публикует задачу на выполнение", "XADD / Redis Streams")

' Очередь -> Воркер
Rel(очередь, воркер, "Передаёт задачу", "XREADGROUP / Redis Streams")

' Воркер -> Бизнес-логика
Rel(воркер, бизнес_логика, "Выполняет реальную операцию", "HTTP/REST")

' Воркер -> Хранилище (сохранение результата)
Rel_D(воркер, хранилище, "Сохраняет результат операции", "RESP (Redis Protocol)")

' Метрики
Rel(шлюз, мониторинг, "Экспортирует метрики", "HTTP /metrics")
Rel(воркер, мониторинг, "Экспортирует метрики", "HTTP /metrics")

@enduml