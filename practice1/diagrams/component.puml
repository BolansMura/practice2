@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Диаграмма компонентов: API-шлюз (внутреннее устройство)

Person_Ext(клиент, "API-клиент", "Отправляет HTTP-запросы")

Container_Boundary(шлюз, "API-шлюз") {
    Component(обработчик, "HTTP-обработчик", "FastAPI Router", "Разбирает запрос, извлекает Idempotency-Key")
    Component(валидатор, "Валидатор ключа", "Middleware", "Проверяет формат ключа (UUID, длина), извлекает из заголовка")
    Component(проверка_кэша, "Проверка кэша", "Асинхронный клиент", "Проверяет в Redis существование ключа и кэшированного ответа")
    Component(публикатор, "Публикатор задач", "Клиент Redis Streams", "Публикует задачу в очередь, если ключ не найден")
    Component(формирователь, "Формирователь ответа", "Сериализатор", "Возвращает кэшированный ответ или 202 Accepted + ID задачи")
    Component(метрики, "Экспортёр метрик", "Клиент Prometheus", "Записывает количество запросов, задержку, попадания/промахи кэша")
}

Container_Ext(redis, "Redis", "Хранилище ключ-значение")
Container_Ext(очередь, "Очередь задач", "Redis Streams")
System_Ext(мониторинг, "Prometheus")

' Клиент -> Обработчик
Rel(клиент, обработчик, "POST /payments\nIdempotency-Key", "HTTP")

' Внутренние связи
Rel(обработчик, валидатор, "вызывает")
Rel(валидатор, проверка_кэша, "вызывает при валидном ключе")
Rel(проверка_кэша, redis, "GET / SETNX", "RESP")
Rel(проверка_кэша, публикатор, "при промахе кэша")
Rel(публикатор, очередь, "XADD задача", "Redis Streams")
Rel(проверка_кэша, формирователь, "при попадании в кэш")
Rel(формирователь, обработчик, "возвращает ответ")  ' <-- добавлено
Rel(обработчик, метрики, "запись метрик")
Rel(метрики, мониторинг, "отдача /metrics")

@enduml