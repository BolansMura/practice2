@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

' Настройки отображения
LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

' Заголовок
title Диаграмма контекста: Система дедупликации запросов

' ===== УЧАСТНИКИ =====

Person(клиент, "API-клиент", "Мобильное приложение или сервис, отправляющий запросы")

System(система, "Система дедупликации", "Принимает ключи идемпотентности, хранит результаты, предотвращает повторное выполнение")

System_Ext(бизнес_логика, "Система бизнес-логики", "Реальная операция (платёж, заказ и т.д.)")

System_Ext(мониторинг, "Система мониторинга", "Сбор метрик и логов")

' ===== СВЯЗИ =====

' Клиент -> Система
Rel(клиент, система, "Отправляет запрос с Idempotency-Key", "HTTP/REST")

' Система -> Бизнес-логика
Rel(система, бизнес_логика, "Выполняет операцию один раз на ключ", "gRPC/HTTP")

' Система -> Мониторинг
Rel(система, мониторинг, "Отдаёт метрики и логи", "Prometheus / OTLP")

' Клиент -> Мониторинг (косвенное наблюдение)
Rel_U(клиент, мониторинг, "Косвенно наблюдает", "через систему")

@enduml